{
  "_note": "All templates use fieldKeyType=name. Replace ALL_CAPS placeholders. Omit optional fields if not needed. Do not include READ-ONLY fields.",

  "create": {
    "contact": {
      "tableId": "tblBVWS56TLkQqW3J4z",
      "records": [
        {
          "fields": {
            "firstname": "FIRST_NAME",
            "lastname": "LAST_NAME",
            "email": "EMAIL",
            "mobile": "MOBILE_OPTIONAL",
            "title": "JOB_TITLE_OPTIONAL",
            "internal_contact_type": { "id": "REC_ID_FROM_CONTACT_TYPE_TABLE" }
          }
        }
      ],
      "_prereqs": "Lookup contact-type record ID first: node scripts/lookup-link-id.js '{\"tableId\":\"tblXWCU7zG6yVPpnH50\",\"fieldId\":\"fldIGDeAfwj7LukG0Kn\",\"value\":\"Employee\"}'"
    },

    "task": {
      "tableId": "tblEtuOcO68wvO2nCoM",
      "records": [
        {
          "fields": {
            "title": "TASK_TITLE",
            "context": "DESCRIPTION_OPTIONAL",
            "task_status": "backlog",
            "start_at": "2024-01-01T09:00:00Z",
            "assigned_to": [{ "id": "REC_ID_FROM_CONTACTS" }],
            "project_name": [{ "id": "REC_ID_FROM_PROJECTS_OPTIONAL" }]
          }
        }
      ],
      "_statusOptions": [
        "backlog",
        "preparing",
        "in-progress",
        "finished",
        "reviewing",
        "approved",
        "delivered",
        "failed",
        "cancelled",
        "onhold"
      ]
    },

    "project": {
      "tableId": "tbluBET7kwcH7WDUxVf",
      "records": [
        {
          "fields": {
            "title": "PROJECT_NAME",
            "context": "DESCRIPTION_OPTIONAL",
            "started_at": "2024-01-01T00:00:00Z",
            "lead_by": [{ "id": "REC_ID_FROM_CONTACTS_OPTIONAL" }],
            "goal": [{ "id": "REC_ID_FROM_GOALS_OPTIONAL" }]
          }
        }
      ]
    },

    "goal": {
      "tableId": "tblJBmCNhL3D3nqgWl5",
      "records": [
        {
          "fields": {
            "title": "GOAL_TITLE",
            "context": "DESCRIPTION_OPTIONAL",
            "goal_type": "objective",
            "deadline": "2024-12-31T00:00:00Z"
          }
        }
      ],
      "_goalTypeOptions": ["objective", "milestone"]
    },

    "it_ticket": {
      "tableId": "tbl8Ule7YoA9LrViroC",
      "records": [
        {
          "fields": {
            "title": "ISSUE_SUMMARY",
            "context": "DETAILED_DESCRIPTION",
            "type": "Software",
            "priority": "Medium",
            "status": "Open",
            "requester_name": [{ "id": "REC_ID_FROM_CONTACTS" }]
          }
        }
      ],
      "_typeOptions": [
        "Hardware",
        "Software",
        "Network",
        "Onboard",
        "Offboard",
        "Access issues",
        "Credential updates",
        "Other"
      ],
      "_priorityOptions": ["Critical", "High", "Medium", "Low"],
      "_statusOptions": ["Open", "In Progress", "On Hold", "Resolved", "Closed"]
    },

    "licence": {
      "tableId": "tbl9fT4iH6G4GXzdA9B",
      "records": [
        {
          "fields": {
            "title": "CONTACT_NAME - APP_NAME",
            "user": [{ "id": "REC_ID_FROM_CONTACTS" }],
            "application": [{ "id": "REC_ID_FROM_APPLICATIONS" }],
            "access_level": "user"
          }
        }
      ],
      "_accessLevelOptions": ["user", "power_user", "admin", "super_admin", "disabled"]
    },

    "knowledge": {
      "tableId": "tblFH854k0qcvWMaXUx",
      "records": [
        {
          "fields": {
            "title": "ARTICLE_TITLE",
            "context": "ARTICLE_CONTENT",
            "is_public": false,
            "knowledge_type": [{ "id": "REC_ID_FROM_KNOWLEDGE_TYPE_OPTIONAL" }]
          }
        }
      ]
    },

    "daily_entry": {
      "tableId": "tblfVf2gSF1axjKxXAP",
      "records": [
        {
          "fields": {
            "Label": "YYYY-MM-DD",
            "daily_tasks": [{ "id": "REC_ID_FROM_TASKS_OPTIONAL" }],
            "daily_log": ""
          }
        }
      ]
    }
  },

  "update": {
    "task_finish": {
      "tableId": "tblEtuOcO68wvO2nCoM",
      "recordId": "REC_ID",
      "fields": {
        "task_status": "finished",
        "finished_at": "2024-01-01T17:00:00Z"
      }
    },

    "ticket_resolve": {
      "tableId": "tbl8Ule7YoA9LrViroC",
      "recordId": "REC_ID",
      "fields": { "status": "Resolved" }
    },

    "ticket_assign": {
      "tableId": "tbl8Ule7YoA9LrViroC",
      "recordId": "REC_ID",
      "fields": {
        "status": "In Progress",
        "assigned_to": [{ "id": "REC_ID_FROM_CONTACTS" }]
      }
    },

    "licence_revoke": {
      "tableId": "tbl9fT4iH6G4GXzdA9B",
      "recordId": "REC_ID",
      "fields": { "access_level": "disabled" }
    },

    "project_complete": {
      "tableId": "tbluBET7kwcH7WDUxVf",
      "recordId": "REC_ID",
      "fields": { "completed_at": "2024-12-31T17:00:00Z" }
    }
  },

  "commonFilters": {
    "tasks_in_progress": {
      "tableId": "tblEtuOcO68wvO2nCoM",
      "filter": {
        "conjunction": "and",
        "filterSet": [
          { "fieldId": "fldsf3yMmXHyvxE3L6w", "operator": "is", "value": "in-progress" }
        ]
      }
    },
    "open_tickets": {
      "tableId": "tbl8Ule7YoA9LrViroC",
      "filter": {
        "conjunction": "and",
        "filterSet": [{ "fieldId": "fld4NzF52VlXTYtlA9v", "operator": "is", "value": "Open" }]
      },
      "orderBy": [{ "fieldId": "fldJRDkWVoUYCtxw9Gs", "order": "asc" }]
    },
    "active_projects": {
      "tableId": "tbluBET7kwcH7WDUxVf",
      "filter": {
        "conjunction": "and",
        "filterSet": [{ "fieldId": "fldIqpgggkK234XeNBA", "operator": "isEmpty" }]
      }
    },
    "contact_by_email": {
      "tableId": "tblBVWS56TLkQqW3J4z",
      "filter": {
        "conjunction": "and",
        "filterSet": [
          { "fieldId": "fldSbbeLg8zRK54MS8n", "operator": "is", "value": "REPLACE_WITH_EMAIL" }
        ]
      }
    },
    "disabled_licences": {
      "tableId": "tbl9fT4iH6G4GXzdA9B",
      "filter": {
        "conjunction": "and",
        "filterSet": [{ "fieldId": "fldw6ftC6qP18mI0dJF", "operator": "is", "value": "disabled" }]
      }
    },
    "objectives_with_deadline": {
      "tableId": "tblJBmCNhL3D3nqgWl5",
      "filter": {
        "conjunction": "and",
        "filterSet": [
          { "fieldId": "fldEaHXR6bqsh68Y9BT", "operator": "is", "value": "objective" },
          { "fieldId": "fldrCJ0X3rn6M1peu0A", "operator": "isNotEmpty" }
        ]
      }
    }
  }
}
